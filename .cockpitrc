[cockpit]
  # Do not change this section
  config = 2026

  # Still Work in Progress

[library]
  # Setup files will be generated for these libraries.
  # 
  #
  # The following libraries are available:
  #   technology    : SG13G2_1.0.1 
  #                   SG13G2_1.1.0
  #                   SG13G2_1.2.1
  #                   SG13G2_1.2.4
  #                   SG13G2_1.2.7
  #                   SG13G2_1.2.10
  #                   SG13G2_1.2.13
  #                   SG13G2_1.3.1
  #                   SG13CMOS5L_1.3.1 #--hacked version for experimental
  #                   SG13CMOS5L_0.1
  #                   SG13CMOS5L_0.2
  #
  #   IO cell       : ixc013g2_iocell_rev0.0.2
  #                   ixc013g2_iocell_rev0.0.4
  #                   ixc013g2_iocell_rev1.1.0
  #                   ixc013g2_iocell_rev1.2.0
  #                   ixc013g2_iocell_rev1.2.1
  #                   open_io_v0.1
  #                   open_io_v0.2
  #                   sg13g2camos5l_io_v0.2 #--hacked version for experimental
  #                   sg13cmos5l_io_v0.1
  #   bondpad       : bondpad_70x70_v0
  #                   bondpad5l_70x70_v0
  #
  #   STD cell      : ixc013g2ng_stdcell_rev0.0.4
  #                   ixc013g2ng_stdcell_rev0.0.6
  #                   ixc013g2ng_stdcell_rev1.1.0
  #                   ixc013g2ng_stdcell_rev1.3.0
  #                   ixc013g2ng_stdcell_rev1.3.1
  #                   open_stdcell_v1.0
  #                   open_stdcell_v2.0
  #                   open_stdcell_v2.1
  #                   open_stdcell_v3.0
  #                   open_stdcell_v3.1
  #                   open_stdcell_v3.2
  #                   open_stdcell_rev0.1.3
  #                   sg13cmos5l_stdcell_v0.1
  #                   ez130_8t_stdcell_v0
  #                   ez130_8t_stdcell_v0.12
  #                   ez130_8t_stdcell_v1.0
  #                   ez130_7t_stdcell_v0
  #  
  #   memories      : RM_IHPSG13_v1.0
  #                   RM_IHPSG13_v2.0
  #                   open_sram_v2.0
  #                   open_sram_v2.1
  #                   open_sram_v2.2
  #
  #   ip            : agingsensor_v1.0            
  #                   agingsensor_v1.1         
  #                   agingsensor_v1.2         
  #    

  libs    = SG13CMOS5L_0.2 \
            sg13cmos5l_stdcell_v0.1 \
            ez130_8t_stdcell_v1.0 \
            sg13cmos5l_io_v0.1 \
            open_sram_v2.2 \
            bondpad5l_70x70_v0

  # If you need other macros, add them to 'macros' below
  # Don't forget the backslash to continue the line!
  #
  # Available macros                area per bit [um^2/bit]
  # -------------------------------------------------------
  # RM_IHPSG13_1P_64x64_c2_bm_bist      12.3
  # RM_IHPSG13_1P_256x8_c3_bm_bist      8.57
  # RM_IHPSG13_1P_256x16_c2_bm_bist     6.87
  # RM_IHPSG13_1P_256x32_c2_bm_bist     6.04
  # RM_IHPSG13_1P_256x48_c2_bm_bist     5.77
  # RM_IHPSG13_1P_256x64_c2_bm_bist     5.69
  # RM_IHPSG13_1P_512x8_c3_bm_bist      6.38
  # RM_IHPSG13_1P_512x16_c2_bm_bist     5.53
  # RM_IHPSG13_1P_512x32_c2_bm_bist     4.87
  # RM_IHPSG13_1P_512x64_c2_bm_bist     4.58
  # RM_IHPSG13_1P_1024x8_c2_bm_bist     6.03
  # RM_IHPSG13_1P_1024x16_c2_bm_bist    4.86
  # RM_IHPSG13_1P_1024x32_c2_bm_bist    4.28
  # RM_IHPSG13_1P_1024x64_c2_bm_bist    4.03
  # RM_IHPSG13_1P_2048x64_c2_bm_bist    3.75
  # RM_IHPSG13_1P_4096x8_c3_bm_bist     4.47
  # RM_IHPSG13_1P_4096x16_c3_bm_bist    3.93
  # RM_IHPSG13_1P_8192x32_c4            3.59
  #
  # RM_IHPSG13_2P_64x22_c2              28.0
  # RM_IHPSG13_2P_64x32_c2              25.7
  # RM_IHPSG13_2P_256x8_c2_bm_bist      18.6
  # RM_IHPSG13_2P_256x16_c2_bm_bist     14.0
  # RM_IHPSG13_2P_256x32_c2_bm_bist     11.8
  # RM_IHPSG13_2P_512x8_c2_bm_bist      14.0
  # RM_IHPSG13_2P_512x16_c2_bm_bist     10.8
  # RM_IHPSG13_2P_512x32_c2_bm_bist     9.19
  # RM_IHPSG13_2P_1024x16_c2_bm_bist    9.47
  # RM_IHPSG13_2P_1024x32_c2_bm_bist    8.06

  macros  = RM_IHPSG13_1P_512x32_c2_bm_bist
            
  
[version]
  # Setup files will be generated for these software versions. 
  # - only versions that can be found in the "kit.ascii" database
  #   can be used (see cockpit.log for the full unix path)
  # - if you change a version you might need to adjust some
  #   startups in the [command] section too... 
  # - use "-update" or "-rewrite" for the changes to take effect  

  # WARNING: The primary purpose is to keep version settings within each
  # project. Fiddling around will most likely result in an unsupported
  # combinations and perl errors. Better update this file as a whole
  # with '-updaterc'. 

  modelsim  =  modelsim-2019.3
  synopsys  =  synopsys-2022.12
  tetramax  =  tetramax-2016.03
  innovus   =  innovus-21
  dfii      =  ic-6
  calibre   =  calibre-2021.3

  #this is actually the oseda version
  klayout   =  klayout-2026.04
   
[command]
  # Startup commands available through the GUI buttons.
  # - startup commands can be modified but need to be compatible with the
  #   setup file versions selected in the [version] section 
  # - to add more modelsim/synopsys startups to the GUI just put your own entries
  #   of the form "(modelsim|synopsys):<label> = <command>" there 
  # - changes will take effect the next time you start

#  emacs                        =  emacs -f vhdl-mode
  modelsim                     =  questa-2019.3 vsim
  synopsys:DC Shell            =  xterm -g 120x40 -T synopsys-2022.12 -e "sh -c 'synopsys-2022.12 dc_shell -64bit | tee view_command.log'"
  synopsys:DesignVision        =  xterm -g 120x40 -T synopsys-2022.12 -e "sh -c 'synopsys-2022.12 design_vision -64bit | tee view_command.log'"
  tetramax                     =  synopsys-2022.12 tmax
  innovus                      =  xterm -g 136x40 -T innovus-21.13 -e "cds_innovus-21.13.000 innovus"
  calibre                      =  xterm -g 120x40 -T calibredrv-2021.3 -e "./start_calibre 2021.3"
  dfii                         =  ./start_dfii
  yosys                        =  xterm -g 120x40 -T yosys -e "oseda -2026.02 yosys -C"
  openroad                     =  xterm -g 120x40 -T openroad -e "oseda -2026.02 openroad -gui"
  klayout                      =  xterm -g 120x40 -T klayout -e "./start_klayout"
  dz:llama                     = llama

